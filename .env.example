# Example environment variables for cgd-frontend (Vite).
# Copy to .env.local for local overrides, or set on the server's .env.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Backend API base URL (leave unset to use the dev backend / same-origin).
# VITE_API_URL=https://backend.dev.candidagenome.org

# Backend API base URL used by the Vite HTML SEO transform for source HTML on
# routes such as /locus/ACT1. Set this on any server that should emit
# locus-specific view-source metadata.
# ENABLE_SEO_HTML=true
# SEO_API_URL=https://backend.candidagenome.org

# Google Analytics 4 measurement id. Tracking activates ONLY when this is set,
# so leave it unset everywhere except production. The production server sets it
# in /opt/cgd_frontend/.env. Local dev and other environments stay untracked.
# VITE_GA_ID=G-XXXXXXXXXX
